  <front>
    <title>Prohibiting RC4 Cipher Suites</title>
    <seriesInfo name="DOI" value="10.17487/RFC7465"/>
    <seriesInfo name="RFC" value="7465"/>
    <seriesInfo name="IETF"/>
    <author initials="A." surname="Popov" fullname="A. Popov"/>
